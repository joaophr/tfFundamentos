public class Aluno {
    String aNome, aLocalNasc;
    int aIdade;
        
    public Aluno(String pNome, int pIdade, String pLocalNasc){
        aNome = pNome;
        aIdade = pIdade;
        aLocalNasc = pLocalNasc;
    }

    public String toString(){
        return "Nome: " + aNome + "\n" + "Idade: " + aIdade + "\n" + "Local de Nascimento: " + aLocalNasc;
    }
}